---
interface Props {
  nav: { id: string; label: string }[];
  pdf: string;
}

const { nav, pdf } = Astro.props;
---

<header class="md-top-bar" role="banner">
  <div class="md-top-bar__inner container-full">
    <a class="md-brand" href="#home" aria-label="Home">
      <span class="md-brand__mark" aria-hidden="true">DR</span>
      <span class="md-brand__text">
        <span class="md-brand__name">David Raj M</span>
        <span class="md-brand__role">Academic CV</span>
      </span>
    </a>

    <nav class="md-nav" aria-label="Primary">
      <div class="md-nav__scroll">
        {nav.map((item) => (
          <a class="md-nav__link" href={`#${item.id}`} data-nav-link={item.id}>
            {item.label}
          </a>
        ))}
      </div>
    </nav>

    <div class="md-top-bar__actions">
      <a class="md-btn md-btn--filled md-top-bar__cta" href={pdf} download>
        <span class="material-symbols-outlined md-btn__icon" aria-hidden="true">download</span>
        <span class="md-top-bar__cta-text">Download CV</span>
      </a>
      <button
        type="button"
        class="md-menu-btn"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="nav-drawer"
        data-nav-toggle
      >
        <span class="material-symbols-outlined md-menu-btn__icon-open" aria-hidden="true">menu</span>
        <span class="material-symbols-outlined md-menu-btn__icon-close" aria-hidden="true">close</span>
      </button>
    </div>
  </div>

  <div class="md-scrim" data-nav-scrim hidden></div>
  <aside class="md-drawer" id="nav-drawer" aria-label="Site navigation" data-nav-drawer hidden>
    <div class="md-drawer__links">
      {nav.map((item) => (
        <a class="md-drawer__link" href={`#${item.id}`} data-nav-link={item.id}>
          <span class="md-drawer__link-text">{item.label}</span>
          <span class="material-symbols-outlined md-drawer__link-icon" aria-hidden="true">chevron_right</span>
        </a>
      ))}
    </div>
    <a class="md-btn md-btn--filled md-drawer__cta" href={pdf} download>
      <span class="material-symbols-outlined md-btn__icon" aria-hidden="true">download</span>
      Download CV
    </a>
  </aside>
</header>

<script>
  const toggle = document.querySelector("[data-nav-toggle]");
  const drawer = document.querySelector("[data-nav-drawer]");
  const scrim = document.querySelector("[data-nav-scrim]");
  const main = document.getElementById("main");
  const navLinks = document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]");

  const DESKTOP_BP = 900;

  function setOpen(open: boolean) {
    if (!drawer || !scrim || !toggle) return;
    drawer.hidden = !open;
    scrim.hidden = !open;
    drawer.setAttribute("aria-hidden", String(!open));
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close navigation menu" : "Open navigation menu");
    document.body.classList.toggle("nav-open", open);
    main?.toggleAttribute("inert", open);
    if (open) {
      const first = drawer.querySelector<HTMLAnchorElement>(".md-drawer__link");
      first?.focus();
    } else {
      toggle.focus();
    }
  }

  function closeIfDesktop() {
    if (window.matchMedia(`(min-width: ${DESKTOP_BP}px)`).matches) {
      setOpen(false);
    }
  }

  toggle?.addEventListener("click", () => {
    setOpen(toggle.getAttribute("aria-expanded") !== "true");
  });

  scrim?.addEventListener("click", () => setOpen(false));

  navLinks.forEach((link) => {
    link.addEventListener("click", () => setOpen(false));
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && document.body.classList.contains("nav-open")) {
      setOpen(false);
    }
  });

  window.addEventListener("resize", closeIfDesktop);

  const sectionIds = [...navLinks]
    .map((l) => l.getAttribute("data-nav-link"))
    .filter((id): id is string => Boolean(id));

  const sections = sectionIds
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => el !== null);

  const visibility = new Map<string, number>();

  function setActiveSection(id: string) {
    navLinks.forEach((l) => {
      const match = l.getAttribute("data-nav-link") === id;
      l.classList.toggle("is-active", match);
      if (match) l.setAttribute("aria-current", "true");
      else l.removeAttribute("aria-current");
    });
  }

  if ("IntersectionObserver" in window && sections.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          visibility.set(entry.target.id, entry.isIntersecting ? entry.intersectionRatio : 0);
        });

        let bestId = sectionIds[0];
        let bestRatio = 0;

        sectionIds.forEach((id) => {
          const ratio = visibility.get(id) ?? 0;
          if (ratio > bestRatio) {
            bestRatio = ratio;
            bestId = id;
          }
        });

        if (bestRatio > 0) setActiveSection(bestId);
      },
      {
        rootMargin: "-15% 0px -55% 0px",
        threshold: [0, 0.1, 0.25, 0.5, 0.75, 1],
      }
    );

    sections.forEach((s) => observer.observe(s));
    setActiveSection(sectionIds[0]);
  }
</script>
