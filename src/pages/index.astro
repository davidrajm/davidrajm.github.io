---
import BaseLayout from "../layouts/BaseLayout.astro";
import TopNav from "../components/TopNav.astro";
import MaterialSection from "../components/MaterialSection.astro";
import cv from "../../data/cv.json";

const nav = [
  { id: "home", label: "Home" },
  { id: "about", label: "About" },
  { id: "research", label: "Research" },
  { id: "skills", label: "Skills" },
  { id: "education", label: "Education" },
  { id: "experience", label: "Experience" },
  { id: "publications", label: "Publications" },
  { id: "teaching", label: "Teaching" },
  { id: "achievements", label: "Achievements" },
  { id: "contact", label: "Contact" },
];

const p = cv.person;
const pdf = cv.meta.pdfPath;
const pubCount =
  cv.publications.peerReviewed.length +
  cv.publications.proceedings.length;
---

<BaseLayout>
  <TopNav nav={nav} pdf={pdf} />

  <main id="main">
    <section id="home" class="hero-section">
      <div class="container-full">
        <article class="hero-card">
          <div class="hero-card__main">
            <div class="hero-card__content">
            <p class="hero-eyebrow">
              <span class="material-symbols-outlined" style="font-size:1rem">verified</span>
              {p.title} · VIT Chennai
            </p>
            <h1>
              Hi, I'm <em>{p.name}</em>
            </h1>
            <p class="hero-degrees">{p.degrees}</p>
            <p class="hero-role">{p.department}</p>
            <p class="hero-affiliation">{p.affiliation}</p>
            <div class="hero-actions">
              <a class="md-btn md-btn--filled" href={pdf} download>
                <span class="material-symbols-outlined md-btn__icon">download</span>
                Download CV
              </a>
              <a class="md-btn md-btn--outlined" href="#publications">
                View publications
                <span class="material-symbols-outlined md-btn__icon">arrow_forward</span>
              </a>
              <a class="md-btn md-btn--tonal" href={`mailto:${p.email}`}>Contact me</a>
            </div>
            <div class="hero-chips md-chip-set">
              <span class="md-chip">Machine Learning</span>
              <span class="md-chip">Fuzzy Logic</span>
              <span class="md-chip">Graph Theory</span>
              <span class="md-chip">Data Science</span>
            </div>
            </div>
            <div class="hero-stat-grid">
            <div class="stat-tile">
              <p class="stat-tile__value">{pubCount}+</p>
              <p class="stat-tile__label">Publications &amp; proceedings</p>
            </div>
            <div class="stat-tile">
              <p class="stat-tile__value">PhD</p>
              <p class="stat-tile__label">Mathematics · MAHE</p>
            </div>
            <div class="stat-tile">
              <p class="stat-tile__value">M.Tech</p>
              <p class="stat-tile__label">AI &amp; ML · VIT Chennai</p>
            </div>
            <div class="stat-tile">
              <p class="stat-tile__value">2025</p>
              <p class="stat-tile__label">Asst. Director, Ranking &amp; Accreditation</p>
            </div>
            </div>
          </div>

          <footer class="hero-profiles" aria-label="Research profiles">
            <div class="hero-profiles__head">
              <span class="material-symbols-outlined" aria-hidden="true">badge</span>
              <span>Research profiles</span>
            </div>
            <div class="hero-profiles__list">
              {cv.profiles.map((profile) => (
                <a
                  class="hero-profile-link"
                  href={profile.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  title={`${profile.label}: ${profile.id}`}
                >
                  <span class="hero-profile-link__label">{profile.label}</span>
                  <span class="hero-profile-link__id">{profile.id}</span>
                  <span class="hero-profile-link__hint">{profile.hint}</span>
                  <span class="material-symbols-outlined hero-profile-link__arrow" aria-hidden="true">open_in_new</span>
                </a>
              ))}
            </div>
          </footer>
        </article>
      </div>
    </section>

    <MaterialSection id="about" title="About me" subtitle="Research focus and professional orientation." icon="person" tint="mint">
      <p class="lead">{cv.about}</p>
      <div class="link-row">
        <a href={cv.links.scholar} target="_blank" rel="noopener noreferrer">
          <span class="material-symbols-outlined">school</span> Google Scholar
        </a>
        <a href={cv.links.github} target="_blank" rel="noopener noreferrer">
          <span class="material-symbols-outlined">code</span> GitHub
        </a>
        <a href={cv.links.youtube} target="_blank" rel="noopener noreferrer">
          <span class="material-symbols-outlined">play_circle</span> YouTube
        </a>
      </div>
    </MaterialSection>

    <MaterialSection id="research" title="Research interests" subtitle="Core themes connecting theory, computation, and applied AI." icon="science" tint="violet">
      <div class="research-pillars">
        {cv.researchAreas.map((area) => (
          <article class={`research-pillar research-pillar--${area.accent}`}>
            <div class="research-pillar__icon" aria-hidden="true">
              <span class="material-symbols-outlined">{area.icon}</span>
            </div>
            <div class="research-pillar__body">
              <h3>{area.title}</h3>
              <p>{area.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </MaterialSection>

    <MaterialSection id="skills" title="Technical skills" subtitle="Methods, tools, and platforms used in research and teaching." icon="code" tint="peach">
      <div class="skill-deck">
        {cv.skills.map((skill) => (
          <article class={`skill-panel skill-panel--${skill.accent}`}>
            <div class="skill-panel__glow" aria-hidden="true"></div>
            <header class="skill-panel__header">
              <div class="skill-panel__icon">
                <span class="material-symbols-outlined">{skill.icon}</span>
              </div>
              <div class="skill-panel__titles">
                <h3>{skill.label}</h3>
                <p>{skill.detail}</p>
              </div>
            </header>
            <div class="skill-panel__tags" role="list">
              {skill.tags.map((tag) => (
                <span class="skill-tag" role="listitem">{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </MaterialSection>

    <MaterialSection id="education" title="Education" icon="school" tint="blue">
      <ul class="md-list">
        {cv.education.map((e) => (
          <li class="md-list-item">
            <div class="md-list-item__meta">{e.period}</div>
            <div>
              <p class="md-list-item__title">{e.degree}</p>
              <p class="md-list-item__subtitle">{e.institution}</p>
              {e.detail && <p class="md-list-item__body">{e.detail}</p>}
            </div>
          </li>
        ))}
      </ul>
    </MaterialSection>

    <MaterialSection id="experience" title="Experience" subtitle="Academic appointments and administrative roles." icon="work" tint="mint">
      <ul class="md-list">
        {cv.appointments.map((a) => (
          <li class="md-list-item">
            <div class="md-list-item__meta">{a.period}</div>
            <div>
              <p class="md-list-item__title">{a.role}</p>
              <p class="md-list-item__subtitle">{a.org}</p>
              {a.detail && <p class="md-list-item__body">{a.detail}</p>}
            </div>
          </li>
        ))}
      </ul>
    </MaterialSection>

    <MaterialSection id="awards" title="Awards and fellowships" icon="military_tech" tint="rose">
      <ul class="md-list">
        {cv.awards.map((a) => (
          <li class="md-list-item">
            <div class="md-list-item__meta">{a.year}</div>
            <div>
              <p class="md-list-item__title">{a.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </MaterialSection>

    <MaterialSection
      id="highlights"
      title="Key publications"
      subtitle={`Selected impact-focused works. Full list on Google Scholar.`}
      icon="auto_stories"
      tint="violet"
    >
      <div class="highlight-grid">
        {cv.keyPublications.map((pub) => (
          <article class="highlight-card">
            <h3>{pub.title}</h3>
            <p>{pub.summary}</p>
            <p class="venue">{pub.venue}</p>
          </article>
        ))}
      </div>
      <p class="text-muted" style="margin-top:1rem">
        <a href={cv.links.scholar}>View complete bibliography →</a>
      </p>
    </MaterialSection>

    <MaterialSection id="publications" title="Publications" subtitle="Peer-reviewed articles, proceedings, and manuscripts under review." icon="menu_book" tint="blue">
      <div class="m-subsection">
        <h3 class="m-subsection__title">
          <span class="material-symbols-outlined">article</span>
          Peer-reviewed
        </h3>
        <div class="pub-grid">
          {cv.publications.peerReviewed.map((pub) => (
            <article class="pub-card">
              <div class="pub-card__year"><span>{pub.year}</span></div>
              <p class="pub-card__text" set:html={pub.citation} />
            </article>
          ))}
        </div>
      </div>

      <div class="m-subsection">
        <h3 class="m-subsection__title">
          <span class="material-symbols-outlined">hub</span>
          Conference proceedings
        </h3>
        <div class="pub-grid">
          {cv.publications.proceedings.map((pub) => (
            <article class="pub-card">
              <div class="pub-card__year"><span>{pub.year}</span></div>
              <p class="pub-card__text" set:html={pub.citation} />
            </article>
          ))}
        </div>
      </div>

      <div class="m-subsection">
        <h3 class="m-subsection__title">
          <span class="material-symbols-outlined">pending</span>
          Under review
        </h3>
        <div class="pub-grid">
          {cv.publications.underReview.map((pub) => (
            <article class="pub-card">
              <div class="pub-card__year"><span>{pub.year}</span></div>
              <p class="pub-card__text" set:html={pub.citation} />
            </article>
          ))}
        </div>
      </div>
    </MaterialSection>

    <MaterialSection id="teaching" title="Teaching and talks" subtitle="Instruction, invited sessions, and conference contributions." icon="cast_for_education" tint="peach">
      <div class="m-subsection">
        <h3 class="m-subsection__title">Teaching experience</h3>
        <ul class="md-list">
          {cv.teaching.map((t) => (
            <li class="md-list-item">
              <div class="md-list-item__meta">{t.period}</div>
              <div>
                <p class="md-list-item__body">{t.text}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
      <div class="m-subsection">
        <h3 class="m-subsection__title">Research supervision</h3>
        <p class="lead">{cv.supervision}</p>
      </div>
      <div class="m-subsection">
        <h3 class="m-subsection__title">Invited talks</h3>
        <ul class="md-list">
          {cv.talks.invited.map((t) => (
            <li class="md-list-item">
              <div class="md-list-item__meta">{t.year}</div>
              <div><p class="md-list-item__body">{t.text}</p></div>
            </li>
          ))}
        </ul>
      </div>
      <div class="m-subsection">
        <h3 class="m-subsection__title">Events organised</h3>
        <ul class="md-list">
          {cv.talks.organised.map((t) => (
            <li class="md-list-item">
              <div class="md-list-item__meta">{t.year}</div>
              <div><p class="md-list-item__body">{t.text}</p></div>
            </li>
          ))}
        </ul>
      </div>
      <div class="m-subsection">
        <h3 class="m-subsection__title">Conference presentations</h3>
        <ul class="md-list">
          {cv.talks.conferences.map((t) => (
            <li class="md-list-item">
              <div class="md-list-item__meta">{t.year}</div>
              <div><p class="md-list-item__body">{t.text}</p></div>
            </li>
          ))}
        </ul>
      </div>
    </MaterialSection>

    <MaterialSection id="achievements" title="Recent achievements" subtitle="Leadership, automation, consultancy, and training (2025–2026)." icon="trending_up" tint="violet" elevated={false}>
      <div class="achievement-stack">
        {cv.achievements.map((group, i) => {
          const meta = cv.achievementMeta[i];
          return (
            <article class={`achievement-panel achievement-panel--${meta.accent}`}>
              <div class="achievement-panel__header">
                <div class="achievement-panel__icon">
                  <span class="material-symbols-outlined">{meta.icon}</span>
                </div>
                <div>
                  <h3>{group.subtitle}</h3>
                  <p class="achievement-panel__scope">{group.scope}</p>
                </div>
              </div>
              <ul class="achievement-panel__list">
                {group.bullets.map((b) => (
                  <li>
                    <span class="material-symbols-outlined achievement-panel__check">check_circle</span>
                    <span set:html={b} />
                  </li>
                ))}
              </ul>
            </article>
          );
        })}
      </div>
    </MaterialSection>

    <MaterialSection id="languages" title="Languages" subtitle="Proficiency across reading, writing, and speaking." icon="translate" tint="mint">
      <div class="lang-skill-list">
        {cv.languages.map((lang) => (
          <div class="lang-skill">
            <div class="lang-skill__head">
              <strong>{lang.name}</strong>
              <span class="lang-skill__pct">{lang.proficiency}%</span>
            </div>
            <div class="lang-skill__track" role="progressbar" aria-valuenow={lang.proficiency} aria-valuemin={0} aria-valuemax={100} aria-label={`${lang.name} proficiency`}>
              <div class="lang-skill__bar" style={`width: ${lang.proficiency}%`}></div>
            </div>
            <span class="lang-skill__level">{lang.level}</span>
          </div>
        ))}
      </div>
    </MaterialSection>

    <MaterialSection id="contact" title="Contact" subtitle="Reach out for collaboration, training, or academic inquiries." icon="mail" tint="blue">
      <div class="contact-unified">
        <div class="contact-unified__item">
          <span class="material-symbols-outlined">mail</span>
          <div>
            <span class="contact-unified__label">Email</span>
            <span class="contact-unified__value">
              <a href={`mailto:${p.email}`}>{p.email}</a>
            </span>
          </div>
        </div>
        <div class="contact-unified__item">
          <span class="material-symbols-outlined">call</span>
          <div>
            <span class="contact-unified__label">Phone</span>
            <span class="contact-unified__value">
              <a href={`tel:${p.phone.replace(/\s/g, "")}`}>{p.phone}</a>
            </span>
          </div>
        </div>
        <div class="contact-unified__divider"></div>
        <div class="contact-unified__item" style="grid-column: 1 / -1;">
          <span class="material-symbols-outlined">location_on</span>
          <div>
            <span class="contact-unified__label">Address</span>
            <span class="contact-unified__value">{p.address}</span>
          </div>
        </div>
      </div>
    </MaterialSection>
  </main>

  <footer class="site-footer">
    <div class="container-full site-footer__inner">
      <div>
        <p class="site-footer__brand">{p.name}</p>
        <p style="margin:0">Last updated {cv.meta.lastUpdated}</p>
      </div>
      <p style="margin:0">
        <a href={pdf}>Download academic CV (PDF)</a>
      </p>
    </div>
  </footer>
</BaseLayout>
